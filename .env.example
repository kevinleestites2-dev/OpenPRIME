# OpenPRIME environment configuration
# Copy to .env and fill in your values

# LLM Providers (add whichever you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default model
PRIME_DEFAULT_PROVIDER=anthropic
PRIME_DEFAULT_MODEL=claude-sonnet-4-20250514

# Messaging platforms (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# System
PRIME_DASHBOARD_PORT=2357  # 2, 3, 5, 7 — the first four prime numbers
PRIME_LOG_LEVEL=info
PRIME_MEMORY_PATH=~/.openprime/memory
PRIME_SKILLS_PATH=~/.openprime/skills
